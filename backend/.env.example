# =====================================================
# 노트마켓 환경변수 설정파일
# 이 파일을 복사해서 .env 파일을 만드세요
# cp .env.example .env
# =====================================================

# ── 데이터베이스 (Supabase에서 복사) ──
DATABASE_URL=postgresql://postgres:[비밀번호]@db.[주소].supabase.co:5432/postgres

# ── JWT 비밀키 (아무 문자나 길게 입력하세요) ──
JWT_ACCESS_SECRET=여기에_최소_32자_이상_아무_문자열_입력_예시_abc123xyz789def456
JWT_REFRESH_SECRET=다른_문자열_입력_ghi789uvw012jkl345mno678

# ── Cloudflare R2 (Cloudflare 대시보드에서 복사) ──
R2_ACCOUNT_ID=여기에_Cloudflare_계정ID
R2_ACCESS_KEY_ID=여기에_R2_Access_Key
R2_SECRET_ACCESS_KEY=여기에_R2_Secret_Key
R2_PRIVATE_BUCKET=notemarket-private
R2_PUBLIC_BUCKET=notemarket-public
R2_PUBLIC_URL=https://pub-[주소].r2.dev

# ── 나이스페이 (https://start.nicepay.co.kr 에서 복사) ──
NICEPAY_CLIENT_ID=여기에_클라이언트ID
NICEPAY_SECRET_KEY=여기에_시크릿키

# ── 서버 설정 ──
PORT=3000
FRONTEND_URL=http://localhost:5500
